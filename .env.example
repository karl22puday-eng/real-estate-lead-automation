# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# In n8n Cloud, these go into n8n Credentials (not node fields). This file is the
# local reference / documentation of what secrets the system needs.

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only (n8n). BYPASSES RLS.
SUPABASE_ANON_KEY=your-anon-public-key        # client-side (dashboard). RLS-restricted.

# --- LLM / Embeddings ---
GROQ_API_KEY=gsk_...                           # https://console.groq.com  (reasoning)
GEMINI_API_KEY=AIza...                          # https://aistudio.google.com (embeddings)

# --- Notifications ---
TELEGRAM_BOT_TOKEN=123456:ABC...                # from @BotFather
TELEGRAM_CHAT_ID=your-numeric-chat-id           # the agent/team chat that gets hot-lead alerts

# --- n8n ---
N8N_WEBHOOK_BASE=https://YOUR-SUBDOMAIN.app.n8n.cloud

# --- Meta Lead Ads (optional, for the Facebook/Instagram lead-ad integration) ---
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN=your-long-lived-page-token
